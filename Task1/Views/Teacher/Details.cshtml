@model Task1.Models.TeacherModel

<h2>Teacher Details</h2>

<dl>
    <dt>Full Name</dt>
    <dd>@Model.FullName</dd>

    <dt>Email</dt>
    <dd>@Model.Email</dd>

    <dt>Phone</dt>
    <dd>@Model.PhoneNumber</dd>

    <dt>Department</dt>
    <dd>@Model.Department</dd>

    <dt>Specialization</dt>
    <dd>@Model.Specialization</dd>

    <dt>Hire Date</dt>
    <dd>@Model.HireDate.ToShortDateString()</dd>

    <dt>Salary</dt>
    <dd>@Model.Salary</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
<a asp-action="Index">Back to List</a>