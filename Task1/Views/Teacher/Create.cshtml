@model Task1.Models.TeacherModel

<h2>Add New Teacher</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div>
        <label asp-for="FullName"></label>
        <input asp-for="FullName" />
        <span asp-validation-for="FullName"></span>
    </div>

    <div>
        <label asp-for="Email"></label>
        <input asp-for="Email" />
        <span asp-validation-for="Email"></span>
    </div>

    <div>
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" />
        <span asp-validation-for="PhoneNumber"></span>
    </div>

    <div>
        <label asp-for="Department"></label>
        <input asp-for="Department" />
        <span asp-validation-for="Department"></span>
    </div>

    <div>
        <label asp-for="Specialization"></label>
        <input asp-for="Specialization" />
        <span asp-validation-for="Specialization"></span>
    </div>

    <div>
        <label asp-for="HireDate"></label>
        <input asp-for="HireDate" type="date" />
        <span asp-validation-for="HireDate"></span>
    </div>

    <div>
        <label asp-for="Salary"></label>
        <input asp-for="Salary" />
        <span asp-validation-for="Salary"></span>
    </div>

    <button type="submit">Save</button>
    <a asp-action="Index">Cancel</a>
</form>