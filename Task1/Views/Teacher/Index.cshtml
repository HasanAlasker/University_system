@model IEnumerable<Task1.Models.TeacherModel>

<h2>Teachers</h2>
<a asp-action="Create">Add New Teacher</a>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Specialization</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var teacher in Model)
        {
            <tr>
                <td>@teacher.FullName</td>
                <td>@teacher.Email</td>
                <td>@teacher.Department</td>
                <td>@teacher.Specialization</td>
                <td>
                    <a asp-action="Details" asp-route-id="@teacher.Id">Details</a>
                    <a asp-action="Edit" asp-route-id="@teacher.Id">Edit</a>
                    <a asp-action="Delete" asp-route-id="@teacher.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>