@model Task1.Models.StudentModel
@using Task1.Enums

<h2>Add New Student</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div>
        <label asp-for="FullName"></label>
        <input asp-for="FullName" />
        <span asp-validation-for="FullName"></span>
    </div>

    <div>
        <label asp-for="Email"></label>
        <input asp-for="Email" />
        <span asp-validation-for="Email"></span>
    </div>

    <div>
        <label asp-for="Age"></label>
        <input asp-for="Age" />
        <span asp-validation-for="Age"></span>
    </div>

    <div>
        <label asp-for="StudentGender"></label>
        <select asp-for="StudentGender">
            @foreach (var gender in Enum.GetValues(typeof(Gender)))
            {
                <option value="@gender">@gender</option>
            }
        </select>
        <span asp-validation-for="StudentGender"></span>
    </div>

    <div>
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" />
        <span asp-validation-for="PhoneNumber"></span>
    </div>

    <div>
        <label asp-for="Address"></label>
        <input asp-for="Address" />
        <span asp-validation-for="Address"></span>
    </div>

    <div>
        <label asp-for="Department"></label>
        <input asp-for="Department" />
        <span asp-validation-for="Department"></span>
    </div>

    <div>
        <label asp-for="EnrollmentDate"></label>
        <input asp-for="EnrollmentDate" type="date" />
        <span asp-validation-for="EnrollmentDate"></span>
    </div>

    <button type="submit">Save</button>
    <a asp-action="Index">Cancel</a>
</form>