@model Task1.Models.StudentModel

<h2>Student Details</h2>

<dl>
    <dt>Full Name</dt>
    <dd>@Model.FullName</dd>

    <dt>Email</dt>
    <dd>@Model.Email</dd>

    <dt>Age</dt>
    <dd>@Model.Age</dd>

    <dt>Gender</dt>
    <dd>@Model.StudentGender</dd>

    <dt>Phone</dt>
    <dd>@Model.PhoneNumber</dd>

    <dt>Address</dt>
    <dd>@Model.Address</dd>

    <dt>Department</dt>
    <dd>@Model.Department</dd>

    <dt>Enrollment Date</dt>
    <dd>@Model.EnrollmentDate.ToShortDateString()</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
<a asp-action="Index">Back to List</a>