@model Task1.Models.CourseModel

<h2>Add New Course</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div>
        <label asp-for="CourseCode"></label>
        <input asp-for="CourseCode" />
        <span asp-validation-for="CourseCode"></span>
    </div>

    <div>
        <label asp-for="CourseName"></label>
        <input asp-for="CourseName" />
        <span asp-validation-for="CourseName"></span>
    </div>

    <div>
        <label asp-for="Description"></label>
        <textarea asp-for="Description"></textarea>
        <span asp-validation-for="Description"></span>
    </div>

    <div>
        <label asp-for="Credits"></label>
        <input asp-for="Credits" />
        <span asp-validation-for="Credits"></span>
    </div>

    <div>
        <label asp-for="Capacity"></label>
        <input asp-for="Capacity" />
        <span asp-validation-for="Capacity"></span>
    </div>

    <div>
        <label asp-for="Department"></label>
        <input asp-for="Department" />
        <span asp-validation-for="Department"></span>
    </div>

    <div>
        <label asp-for="TeacherId"></label>
        <select asp-for="TeacherId">
            <option value="">-- Select Teacher --</option>
            @foreach (var teacher in ViewBag.Teachers)
            {
                <option value="@teacher.Id">@teacher.FullName</option>
            }
        </select>
        <span asp-validation-for="TeacherId"></span>
    </div>

    <div>
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="date" />
        <span asp-validation-for="StartDate"></span>
    </div>

    <div>
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" />
        <span asp-validation-for="EndDate"></span>
    </div>

    <button type="submit">Save</button>
    <a asp-action="Index">Cancel</a>
</form>