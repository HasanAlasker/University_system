@model IEnumerable<Task1.Models.CourseModel>

<h2>Courses</h2>
<a asp-action="Create">Add New Course</a>

<table>
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Department</th>
            <th>Credits</th>
            <th>Teacher</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.CourseCode</td>
                <td>@course.CourseName</td>
                <td>@course.Department</td>
                <td>@course.Credits</td>
                <td>@course.Teacher?.FullName</td>
                <td>
                    <a asp-action="Details" class="black" asp-route-id="@course.Id">Details</a>
                    <a asp-action="Edit" asp-route-id="@course.Id">Edit</a>
                    <a asp-action="Delete" class="red" asp-route-id="@course.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>